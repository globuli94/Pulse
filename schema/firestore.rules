rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------------------------------------------------------------
    // users/{uid}
    // ---------------------------------------------------------------
    match /users/{uid} {

      // Any authenticated user may read any profile
      allow read: if request.auth != null;

      // Owner may create their own document on first sign-in
      allow create: if request.auth != null
                    && request.auth.uid == uid;

      // Owner may update only the permitted profile fields
      allow update: if request.auth != null
                    && request.auth.uid == uid
                    && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['displayName', 'bio', 'avatarUrl', 'username']);

      // Owner may delete their own document as part of account deletion
      allow delete: if request.auth != null && request.auth.uid == uid;
    }

    // ---------------------------------------------------------------
    // follows/{followId}
    // ---------------------------------------------------------------
    match /follows/{followId} {

      // Any authenticated user may read any follow document (e.g. check if following)
      allow read: if request.auth != null;

      // Owner may create a follow — followerId must match the authenticated user
      allow create: if request.auth != null
                    && request.resource.data.followerId == request.auth.uid;

      // Owner may delete their own follow
      allow delete: if request.auth != null
                    && resource.data.followerId == request.auth.uid;

      // Followee may delete the follow document on account deletion
      allow delete: if request.auth != null
                    && resource.data.followeeId == request.auth.uid;
    }

    // ---------------------------------------------------------------
    // posts/{postId}
    // ---------------------------------------------------------------
    match /posts/{postId} {

      // Any authenticated user may read any post
      allow read: if request.auth != null;

      // Authenticated user may create a post they own
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.userId;

      // Only author may delete their own post
      allow delete: if request.auth != null
                    && request.auth.uid == resource.data.userId;

    }

    // ---------------------------------------------------------------
    // likes/{likeId}  — likeId = "{userId}_{postId}"
    // ---------------------------------------------------------------
    match /likes/{likeId} {

      // Any authenticated user may read a like document (e.g. check if current user liked a post)
      allow read: if request.auth != null;

      // Owner may create their own like — userId in the document must match the authenticated user
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;

      // Owner may delete their own like
      allow delete: if request.auth != null
                    && resource.data.userId == request.auth.uid;
    }

    // ---------------------------------------------------------------
    // comments/{commentId}
    // ---------------------------------------------------------------
    match /comments/{commentId} {

      // Any authenticated user may read comments (e.g. fetch all comments for a post)
      allow read: if request.auth != null;

      // Authenticated user may create a comment they author
      allow create: if request.auth != null
                    && request.resource.data.authorId == request.auth.uid;

      // Author may delete their own comment
      allow delete: if request.auth != null
                    && resource.data.authorId == request.auth.uid;
    }

    // ---------------------------------------------------------------
    // notifications/{notificationId}
    // ---------------------------------------------------------------
    match /notifications/{notificationId} {

      // Any authenticated user may create a notification for another user (actor writes for recipient)
      allow create: if request.auth != null;

      // Recipient may read their own notifications
      allow read: if request.auth != null
                  && request.auth.uid == resource.data.userId;

      // Recipient may update isRead only
      allow update: if request.auth != null
                    && request.auth.uid == resource.data.userId
                    && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['isRead']);

      // Recipient or actor may delete notification (account deletion cleanup)
      allow delete: if request.auth != null
                    && (resource.data.userId == request.auth.uid
                        || resource.data.actorId == request.auth.uid);
    }

    // ---------------------------------------------------------------
    // conversations/{conversationId}
    // ---------------------------------------------------------------
    match /conversations/{conversationId} {

      // Participant may read a conversation they belong to
      allow read: if request.auth != null
                  && request.auth.uid in resource.data.participantIds;

      // Authenticated user may create a conversation they are a participant of
      allow create: if request.auth != null
                    && request.auth.uid in request.resource.data.participantIds;

      // Participant may update conversation metadata (lastMessageText, lastMessageAt, unreadCounts)
      allow update: if request.auth != null
                    && request.auth.uid in resource.data.participantIds;

      // Participant may delete conversation (account deletion cleanup)
      allow delete: if request.auth != null
                    && request.auth.uid in resource.data.participantIds;

      // ---------------------------------------------------------------
      // conversations/{conversationId}/messages/{messageId}
      // ---------------------------------------------------------------
      match /messages/{messageId} {

        // Participant of the parent conversation may read messages
        allow read: if request.auth != null
                    && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;

        // Participant of the parent conversation may send a message
        allow create: if request.auth != null
                      && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds
                      && request.resource.data.senderId == request.auth.uid;

        // Participant of the parent conversation may delete message (account deletion cleanup)
        allow delete: if request.auth != null
                      && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
      }
    }

  }
}
