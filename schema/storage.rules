rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ---------------------------------------------------------------
    // avatars/{uid}
    // ---------------------------------------------------------------
    // Owner may read and write their own avatar.
    // Any authenticated user may read any avatar.
    match /avatars/{uid} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

  }
}
